{
  "name": "Set — Retornar dados para Tool",
  "type": "n8n-nodes-base.set",
  "typeVersion": 3.4,
  "parameters": {
    "assignments": {
      "assignments": [
        {
          "name": "status",
          "value": "pending",
          "type": "string"
        },
        {
          "name": "pix_qr_code",
          "value": "={{ String($json.pix_qr_code || $json.pix_key || '').trim() }}",
          "type": "string"
        },
        {
          "name": "pix_copia_e_cola",
          "value": "={{ String($json.pix_copia_e_cola || $json.pix_qr_code || $json.pix_key || '').trim() }}",
          "type": "string"
        },
        {
          "name": "valor",
          "value": "={{ Number($json.valor || 49.9) }}",
          "type": "number"
        }
      ]
    },
    "options": {}
  }
}
