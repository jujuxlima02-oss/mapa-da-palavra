      "name": "Get Follow-up Counter",
      "type": "n8n-nodes-base.httpRequest",
      "id": "get-counter-1778164119884-a1b2c3d4e5f6a7",
      "typeVersion": 4.2,
      "position": [
        1200,
        300
      ],
      "parameters": {
        "method": "GET",
        "url": "=http://chatwoot_rails:3000/api/v1/accounts/{{$env.CHATWOOT_ACCOUNT_ID}}/conversations/{{$json.conversation_id}}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "api_access_token",
              "value": "={{ $env.CHATWOOT_API_ACCESS_TOKEN }}"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "name": "Parse Follow-up Counter",
      "type": "n8n-nodes-base.code",
      "id": "parse-counter-1778164119884-b2c3d4e5f6a7b8",
      "typeVersion": 2,
      "position": [
        1400,
        300
      ],
      "parameters": {
        "jsCode": "const messages = $input.all();\nlet count = 0;\nfor (const item of messages) {\n  const payload = item.json?.payload || [];\n  const msgs = Array.isArray(payload) ? payload : [];\n  for (const msg of msgs.reverse()) {\n    if (msg.private === true && typeof msg.content === 'string' && msg.content.startsWith('follow-up-count:')) {\n      count = parseInt(msg.content.replace('follow-up-count:', '').trim()) || 0;\n      break;\n    }\n  }\n  if (count > 0) break;\n}\nreturn [{ json: { followUpCount: count, conversation_id: $('Send Message').item.json.conversation_id } }];"
      }
    }
  ],
